        N_vals(k), Gain_dBi(k), HPBW(k), SNR_req(k), Cap_20dB(k));
end
fprintf('%s\n', repmat('-', 72, 1));
fprintf('Unidades: Ganancia [dBi], HPBW [°], SNR req [dB], Cap [Gbps]\n\n');

